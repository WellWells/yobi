{
  "name": "yobi",
  "version": "1.2.0",
  "description": "Yobi — desktop AI automation that drives the web interfaces of ChatGPT, Gemini, Perplexity, and Duck.ai in a built-in browser window. Includes AgentFlow visual workflows and Telegram bot control. Built with Electron & React. Automating these web interfaces is against the providers' terms of service; see the README disclosure.",
  "author": "WellsTsai",
  "repository": {
    "type": "git",
    "url": "https://github.com/WellWells/yobi.git"
  },
  "bugs": {
    "url": "https://github.com/WellWells/yobi/issues"
  },
  "homepage": "https://github.com/WellWells/yobi#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "out/main/index.js",
  "scripts": {
    "start": "electron out/main/index.js",
    "dev": "tsx scripts/electron-dev.ts",
    "build:compile": "vite build -c vite.main.config.ts && vite build -c vite.preload.config.ts && vite build -c vite.renderer.config.ts",
    "prepare:icons": "tsx scripts/generate-icons.ts",
    "licenses:generate": "tsx scripts/generate-licenses.ts",
    "build:win": "npm run prepare:icons && npm run build:compile && npm run licenses:generate && electron-builder --win",
    "build:mac": "npm run prepare:icons && npm run build:compile && npm run licenses:generate && electron-builder --mac",
    "build": "npm run build:win",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "i18n:check": "tsx scripts/i18n-check.ts"
  },
  "keywords": [
    "electron",
    "desktop-app",
    "cross-platform",
    "ai",
    "ai-automation",
    "automation",
    "workflow-automation",
    "agentflow",
    "llm",
    "chatgpt",
    "gemini",
    "perplexity",
    "duckai",
    "telegram-bot",
    "global-hotkey",
    "clipboard",
    "productivity",
    "markdown",
    "react",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@grammyjs/conversations": "^2.1.1",
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@mantine/modals": "^9.4.1",
    "@mantine/notifications": "^9.4.1",
    "@tanstack/react-virtual": "^3.14.5",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.21",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "fdir": "^6.5.0",
    "grammy": "^1.44.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.22.0",
    "marked": "^18.0.5",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.3",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "react-simple-code-editor": "^0.14.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "happy-dom": "^20.10.6",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "postcss": "^8.5.16",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.wellstsai.yobi",
    "productName": "Yobi",
    "executableName": "Yobi",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "!out/**/*.js.map",
      "!out/**/*.css.map"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "WellWells",
        "repo": "yobi"
      }
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "*.png",
          "*.ico",
          "*.icns"
        ]
      },
      {
        "from": "LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "THIRD-PARTY-LICENSES.txt",
        "to": "THIRD-PARTY-LICENSES.txt"
      }
    ],
    "win": {
      "icon": "assets/icon-win.ico",
      "target": [
        "nsis"
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "artifactName": "Yobi-${version}-win-x64-Setup.exe"
    },
    "mac": {
      "icon": "assets/icon-mac.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "Yobi-${version}-mac-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "Yobi-${version}-mac-${arch}.dmg"
    }
  },
  "overrides": {
    "yauzl": "^3.3.1"
  }
}
