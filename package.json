{
  "name": "desktop-agent-center",
  "version": "1.1.1",
  "description": "Desktop Agent Center (DAC) — Free, no-API-key AI automation desktop app. Integrates ChatGPT/Gemini via global hotkeys, features AgentFlow visual workflows, and supports Telegram bot control. Built with Electron & React.",
  "author": "WellsTsai",
  "repository": {
    "type": "git",
    "url": "https://github.com/WellWells/desktop-agent-center.git"
  },
  "bugs": {
    "url": "https://github.com/WellWells/desktop-agent-center/issues"
  },
  "homepage": "https://github.com/WellWells/desktop-agent-center#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "out/main/index.js",
  "scripts": {
    "start": "electron out/main/index.js",
    "dev": "tsx scripts/electron-dev.ts",
    "build:compile": "vite build -c vite.main.config.ts && vite build -c vite.preload.config.ts && vite build -c vite.renderer.config.ts",
    "prepare:icons": "tsx scripts/generate-icons.ts",
    "build:win": "npm run prepare:icons && npm run build:compile && electron-builder --win",
    "build:mac": "npm run prepare:icons && npm run build:compile && electron-builder --mac",
    "build": "npm run build:win",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "i18n:check": "tsx scripts/i18n-check.ts"
  },
  "keywords": [
    "electron",
    "gemini",
    "clipboard",
    "automation",
    "no-api-key"
  ],
  "license": "MIT",
  "dependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "@mantine/core": "^9.2.1",
    "@mantine/hooks": "^9.2.1",
    "@mantine/modals": "^9.2.1",
    "@mantine/notifications": "^9.2.1",
    "@tanstack/react-virtual": "^3.13.25",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.20",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "fdir": "^6.5.0",
    "grammy": "^1.43.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.4",
    "node-cron": "^4.2.1",
    "postcss": "^8.5.15",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.1.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "build": {
    "appId": "com.wellstsai.dac",
    "productName": "Desktop Agent Center",
    "executableName": "DesktopAgentCenter",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "!out/**/*.js.map",
      "!out/**/*.css.map"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "WellWells",
        "repo": "desktop-agent-center"
      }
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "*.png",
          "*.ico",
          "*.icns"
        ]
      },
      {
        "from": "LICENSE",
        "to": "LICENSE"
      }
    ],
    "win": {
      "icon": "assets/icon-win.ico",
      "target": [
        "nsis"
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "artifactName": "DesktopAgentCenter-${version}-win-x64-Setup.exe"
    },
    "mac": {
      "icon": "assets/icon-mac.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "DesktopAgentCenter-${version}-mac-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "DesktopAgentCenter-${version}-mac-${arch}.dmg"
    }
  },
  "overrides": {
    "yauzl": "^3.3.1"
  }
}